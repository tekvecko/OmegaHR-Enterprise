@app.route('/api/security_audit_check')
def security_audit_check():
    # Vazba: Network + Assets -> Bezpečnostní audit
    # Zjistí, zda jsou v síti zařízení, která nejsou v evidenci majetku
    if not session.get('logged_in'): return redirect(url_for('login'))
    
    # Simulace porovnání LAN Reaperu a Assets
    known_ips = [a['last_ip'] for a in query_db("SELECT last_ip FROM assets WHERE last_ip IS NOT NULL")]
    # Zde by byl skutečný scan, pro ukázku simulujeme detekci
    alert = "Integrita sítě: Všechna zařízení v evidenci."
    return {"status": "safe", "msg": alert}

@app.route('/api/terminate_contract/<token>')
def terminate_contract(token):
    # Vazba: HR -> Assets + Audit
    # Totální vyvázání zaměstnance
    if not session.get('logged_in'): return redirect(url_for('login'))
    
    # 1. Uvolnění veškerého majetku
    query_db("UPDATE assets SET owner_token=NULL, status='RETURNED' WHERE owner_token=?", (token,))
    # 2. Změna stavu v HR
    query_db("UPDATE candidates SET status='TERMINATED', onboarding_status='ARCHIVED' WHERE token=?", (token,))
    # 3. Záznam do auditní stopy
    log_action(session.get('user'), "TERMINATION", f"Full termination of {token}. Assets reclaimed.")
    
    return redirect(url_for('view_agenda'))

