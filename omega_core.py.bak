# --- MODUL B: DIGITAL SIGNATURE (HASHING) ---
@app.route('/api/sign_contract/<token>')
def sign_contract(token):
    import hashlib
    user = query_db("SELECT * FROM candidates WHERE token=?", (token,), one=True)
    # Simulace digitálního podpisu vytvořením hashe z dat a timestampu
    sig_data = f"{user['name']}-{user['mojeid_sub']}-{datetime.now()}"
    contract_hash = hashlib.sha256(sig_data.encode()).hexdigest()
    query_db("UPDATE candidates SET contract_hash=?, status='CONTRACT_SIGNED' WHERE token=?", (contract_hash, token))
    log_action("SYSTEM", "CONTRACT_SIGNED", f"Contract for {token} digitally hashed: {contract_hash[:10]}...")
    return redirect(request.referrer)

# --- MODUL C: FINANCIAL ANALYTICS ---
@app.route('/admin/finance')
def financial_dashboard():
    if not session.get('logged_in'): return redirect(url_for('login'))
    employees = query_db("SELECT name, salary_base, tax_rate, insurance_rate FROM candidates WHERE status='ACTIVE' OR status='CONTRACT_SIGNED'")
    stats = []
    total_cost = 0
    for e in employees:
        sal = float(e['salary_base'] or 0)
        tax = sal * e['tax_rate']
        ins = sal * e['insurance_rate']
        netto = sal - tax - ins
        stats.append({'name': e['name'], 'brutto': sal, 'netto': netto, 'cost': sal * 1.34}) # Superhrubá simulace
        total_cost += sal * 1.34
    return render_template('finance_admin.html', stats=stats, total=total_cost)

if __name__ == '__main__':
    app.run(host="0.0.0.0", port=8080)
