def run_hr_automation():
    # 1. Automatické povýšení po verifikaci MojeID
    # Pokud je ověřen a je ve stavu 'new', posuneme ho dál
    query_db("UPDATE candidates SET status='VERIFIED' WHERE is_verified=1 AND status='new'")
    
    # 2. Kontrola integrity složek pro aktivní zaměstnance
    active_emps = query_db("SELECT token FROM candidates WHERE status='ACTIVE'")
    for emp in active_emps:
        emp_path = f"/data/data/com.termux/files/home/OmegaPlatinum_PROD/work_vault/{emp['token']}"
        if not os.path.exists(emp_path):
            os.makedirs(emp_path)
            # Vytvoření základního souboru agendy
            with open(f"{emp_path}/profile.txt", 'w') as f:
                f.write(f"OMEGA PROFILE: {emp['token']}\nCreated: {datetime.now()}")

@app.before_request
def auto_trigger():
    # Spustí se při každé interakci s dashboardem, udržuje data v kondici
    try: run_hr_automation()
    except: pass

@app.route('/api/finalize_onboarding/<token>')
def finalize_onboarding(token):
    if not session.get('logged_in'): return redirect(url_for('login'))
    
    # Validace před aktivací
    emp = query_db("SELECT * FROM candidates WHERE token=?", (token,), one=True)
    assets = query_db("SELECT id FROM assets WHERE owner_token=?", (token,))
    
    if not emp['is_verified']:
        return "❌ CHYBA: Nelze aktivovat neověřeného člena (MojeID missing).", 400
    if not assets:
        return "⚠️ VAROVÁNÍ: Člen nemá přiřazen žádný majetek. Chcete pokračovat?", 200 # Pro zjednodušení jen varování

    query_db("UPDATE candidates SET status='ACTIVE', onboarding_status='READY' WHERE token=?", (token,))
    log_action(session.get('user'), "AUTO_ONBOARD", f"Onboarding finalized for {token}")
    return redirect(url_for('view_agenda'))


@app.route('/generate_verified_contract/<token>')
def generate_verified_contract(token):
    if not session.get('logged_in'): return redirect(url_for('login'))
    emp = query_db("SELECT * FROM candidates WHERE token=?", (token,), one=True)
    if not emp: return "Subjekt nenalezen", 404
    
    from fpdf import FPDF
    import hashlib
    pdf = FPDF()
    pdf.add_font('Roboto', '', '/data/data/com.termux/files/home/OmegaPlatinum_PROD/fonts/System-Roboto.ttf')
    pdf.add_page()
    pdf.set_font('Roboto', size=16)
    pdf.cell(190, 15, text="PRÁVNĚ OVĚŘENÁ SMLOUVA OMEGA", align='C', ln=True)
    pdf.set_font('Roboto', size=10)
    pdf.ln(10)
    
    # Právní data z MojeID
    pdf.multi_cell(190, 8, text=f"Zaměstnanec: {emp['full_name_mojeid'] or emp['name']}\nBydliště: {emp['address_mojeid'] or 'Ověřeno v registru'}\nMojeID SUB: {emp['mojeid_sub'] or 'N/A'}")
    pdf.ln(10)
    pdf.multi_cell(190, 8, text="Tato smlouva je generována na základě úspěšné verifikace identity skrze systém MojeID.")
    
    doc_hash = hashlib.sha256(f"{token}{datetime.now()}".encode()).hexdigest()
    pdf.set_y(-20)
    pdf.set_font(size=7)
    pdf.cell(190, 10, text=f"DIGITÁLNÍ PEČEŤ: {doc_hash}", align='C')
    
    filename = f"Kontrakt_VERIFIED_{token}.pdf"
    pdf.output(os.path.join('/data/data/com.termux/files/home/OmegaPlatinum_PROD/contracts', filename))
    return send_from_directory('/data/data/com.termux/files/home/OmegaPlatinum_PROD/contracts', filename)


