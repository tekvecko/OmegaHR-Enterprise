    return jsonify({"active_personnel": count})


import hashlib

@app.route('/login', methods=['GET', 'POST'])
def login():
    if request.method == 'POST':
        user = request.form.get('username')
        pw = request.form.get('password')
        pw_hash = hashlib.sha256(pw.encode()).hexdigest()
        
        account = query_db("SELECT * FROM users WHERE username=?", (user,), one=True)
        
        if account:
            if account['failed_attempts'] >= 5:
                log_action(user, "LOGIN_BLOCKED", "Too many failed attempts")
                return "Účet je zablokován. Kontaktujte systémového správce.", 403
            
            if account['password_hash'] == pw_hash:
                session.clear()
                session['logged_in'] = True
                session['user'] = user
                session['role'] = account['role']
                query_db("UPDATE users SET failed_attempts=0, last_login=CURRENT_TIMESTAMP WHERE username=?", (user,))
                log_action(user, "LOGIN", "Success")
                return redirect(url_for('index'))
            else:
                query_db("UPDATE users SET failed_attempts = failed_attempts + 1 WHERE username=?", (user,))
                log_action(user, "LOGIN_FAIL", f"Wrong password for {user}")
        
        return "Neplatné přihlašovací údaje", 401
    return render_template('login.html')


