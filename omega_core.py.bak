@app.route('/new', methods=['GET', 'POST'])
def new_candidate():
    if not session.get('logged_in'): return redirect(url_for('login'))
    if request.method == 'POST':
        name = request.form.get('name')
        token = request.form.get('token') or str(os.urandom(4).hex().upper())
        mojeid = request.form.get('mojeid')
        query_db("INSERT INTO candidates (token, name, mojeid_sub, status, hired_at) VALUES (?, ?, ?, 'ACTIVE', DATE('now'))",
                 (token, name, mojeid))
        return redirect(url_for('index'))
    return render_template('new.html')

